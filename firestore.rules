rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Claims-first authorization keeps rules cheap at scale.
    function isSignedIn() {
      return request.auth != null;
    }

    function claimRole() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }

    function isAdminByProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdminByEmail() {
      return isSignedIn() &&
        request.auth.token.email is string &&
        request.auth.token.email == 'ca.matjark@gmail.com';
    }

    function isSellerByProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function isVendorByProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    function isApprovedByProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        claimRole() == 'admin' ||
        isAdminByProfile() ||
        isAdminByEmail()
      );
    }

    function isVendor() {
      return isSignedIn() && (
        isAdmin() ||
        claimRole() == 'seller' ||
        claimRole() == 'vendor' ||
        isSellerByProfile() ||
        isVendorByProfile()
      );
    }

    function isApprovedVendor() {
      return isVendor() && (
        isAdmin() ||
        request.auth.token.sellerApproved == true ||
        request.auth.token.vendorApproved == true ||
        isApprovedByProfile()
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requestVendorId() {
      return request.resource.data.vendorId is string
        ? request.resource.data.vendorId
        : (
          request.resource.data.sellerId is string
            ? request.resource.data.sellerId
            : ''
        );
    }

    function resourceVendorId() {
      return resource.data.vendorId is string
        ? resource.data.vendorId
        : (
          resource.data.sellerId is string
            ? resource.data.sellerId
            : ''
        );
    }

    function productIsPublic(data) {
      return data.isApproved == true && data.isActive != false;
    }

    function orderVendorMatches() {
      return resource.data.vendorId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid;
    }

    function immutableOrderFieldsUnchanged() {
      return request.resource.data.customerId == resource.data.customerId &&
        request.resource.data.items == resource.data.items &&
        request.resource.data.totalAmount == resource.data.totalAmount &&
        request.resource.data.subtotalAmount == resource.data.subtotalAmount &&
        request.resource.data.discountAmount == resource.data.discountAmount &&
        request.resource.data.taxAmount == resource.data.taxAmount &&
        request.resource.data.shippingAmount == resource.data.shippingAmount &&
        request.resource.data.vendorId == resource.data.vendorId &&
        request.resource.data.sellerId == resource.data.sellerId &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false;

      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'phone',
          'photoURL',
          'language',
          'themeMode',
          'defaultAddress',
          'updatedAt'
        ])
      );

      allow delete: if isAdmin();

      match /favorites/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Canonical vendor collection.
    match /vendors/{vendorId} {
      allow read: if resource.data.approved == true || isOwner(vendorId) || isAdmin();
      allow create: if isOwner(vendorId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.approved == false;
      allow update: if isAdmin() || (
        isOwner(vendorId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.approved == resource.data.approved
      );
      allow delete: if isAdmin();
    }

    // Backward compatibility for the existing project.
    match /sellers/{sellerId} {
      allow read: if resource.data.approved == true || isOwner(sellerId) || isAdmin();
      allow create: if isOwner(sellerId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.approved == false;
      allow update: if isAdmin() || (
        isOwner(sellerId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.approved == resource.data.approved
      );
      allow delete: if isAdmin();
    }

    match /seller_requests/{requestId} {
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.uid == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if productIsPublic(resource.data) || isAdmin() || (
        isSignedIn() && (
          resource.data.sellerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid
        )
      );

      allow create: if isApprovedVendor() && requestVendorId() == request.auth.uid;

      allow update: if isAdmin() || (
        isApprovedVendor() &&
        (
          resource.data.sellerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid
        ) &&
        requestVendorId() == request.auth.uid &&
        request.resource.data.createdAt == resource.data.createdAt
      );

      allow delete: if isAdmin() || (
        isApprovedVendor() && (
          resource.data.sellerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid
        )
      );

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (
          isSignedIn() && resource.data.userId == request.auth.uid
        );
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /items/{itemId} {
        // Cart snapshots may include display prices for UX, but checkout ignores
        // client prices and re-prices on the server.
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.customerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        )
      );

      // Orders are created and priced server-side only.
      allow create: if false;

      allow update: if isAdmin() || (
        isApprovedVendor() &&
        (
          resource.data.vendorId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid
        ) &&
        immutableOrderFieldsUnchanged() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'returnRequestStatus',
          'hiddenForSeller',
          'trackingNumber',
          'trackingUrl',
          'updatedAt',
          'processingAt',
          'awaitingShipmentAt',
          'shippedAt',
          'outForDeliveryAt',
          'deliveredAt',
          'returnedAt'
        ])
      );

      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.customerId == request.auth.uid
      );
      allow create, update: if false;
      allow delete: if false;
    }

    match /returns/{returnId} {
      allow create: if isSignedIn() &&
        request.resource.data.customerId == request.auth.uid;
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.customerId == request.auth.uid ||
          resource.data.sellerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid
        )
      );
      allow update: if isAdmin() || (
        isApprovedVendor() && (
          resource.data.sellerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid
        )
      );
      allow delete: if false;
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /discount_codes/{couponId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'read',
          'isRead',
          'updatedAt'
        ])
      );
    }

    match /admin_broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
